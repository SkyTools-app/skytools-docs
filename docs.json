{
  "$schema": "https://mintlify.com/docs.json",
  "name": "SkyTools API",
  "theme": "mint",
  "logo": {
    "light": "/images/logo.png",
    "dark": "/images/logo.png"
  },
  "favicon": "/images/favicon.ico",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "topbarLinks": [
    {
      "name": "Dashboard",
      "url": "https://developer.skytools.app/keys"
    }
  ],
  "topbarCtaButton": {
    "name": "Get API Key",
    "url": "https://developer.skytools.app/keys"
  },
  "anchors": [
    {
      "name": "API Status",
      "icon": "signal",
      "url": "https://skytools.app"
    },
    {
      "name": "Main App",
      "icon": "globe",
      "url": "https://skytools.app"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "introduction",
              "authentication",
              "rate-limits",
              "errors"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "endpoints/bazaar",
              "endpoints/bazaar-history",
              "endpoints/auctions",
              "endpoints/lowest-bins",
              "endpoints/player",
              "endpoints/profile",
              "endpoints/items",
              "endpoints/collections",
              "endpoints/mayor",
              "endpoints/fire-sales",
              "endpoints/guild",
              "endpoints/recipes"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.yaml"
      }
    ]
  },
  "footerSocials": {
    "github": "https://github.com/JashanMaan28"
  },
  "errors": {
    "404": {
      "redirect": false,
      "title": "Lost in the Void",
      "description": "This endpoint doesn't exist — maybe it fell into the **Catacombs**. Try the [API reference](/introduction) or search above."
    }
  },
  "contextual": {
    "options": ["copy", "chatgpt", "claude", "mcp", "cursor", "vscode"]
  },
  "api": {
    "baseUrl": "https://api.skytools.app",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    }
  }
}
